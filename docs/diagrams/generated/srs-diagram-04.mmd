graph TD
    subgraph "Presentation Layer"
        UI[UI Widgets]
        NM[Notifiers/Blocs<br/>State Management]
        RV[Route Views]
    end
    
    subgraph "Application Layer"
        UC[Use Cases]
        DTO[DTOs]
    end
    
    subgraph "Domain Layer"
        ENT[Entities]
        REP[Repository Interfaces]
